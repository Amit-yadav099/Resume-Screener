generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Candidate {
  id              Int      @id @default(autoincrement())
  name            String
  resume_path     String
  match_score     Int
  matching_skills String[]
  missing_skills  String[]
  created_at      DateTime @default(now())
}
